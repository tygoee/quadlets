[Unit]
Description=Authentik worker container
Requires=authentik-postgres.container
After=authentik-postgres.container

[Container]
ContainerName=authentik-worker
Image=ghcr.io/goauthentik/server:2026.5.5
Exec=worker
User=root
AutoUpdate=registry
Volume=authentik-data:/data
Volume=authentik-certs:/certs
Network=authentik.network
UserNS=auto
EnvironmentFile=/etc/containers/environment/authentik.env

[Service]
Restart=unless-stopped

[Install]
WantedBy=default.target
