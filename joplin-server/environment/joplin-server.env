APP_BASE_URL={{ joplin.url }}
API_BASE_URL={{ joplin.url }}
APP_PORT=22300

DB_CLIENT=pg
POSTGRES_PASSWORD={{ joplin.postgres.password }}
POSTGRES_DATABASE=joplin
POSTGRES_USER=joplin
POSTGRES_PORT=5432
# In podman, localhost or 127.0.0.1 won't work. See https://github.com/laurent22/joplin/issues/5048
POSTGRES_HOST=::1

MAILER_ENABLED=0

SAML_ENABLED={{ joplin.saml_enabled | lower }}
SAML_IDP_CONFIG_FILE=/config/joplin-idp.xml
SAML_SP_CONFIG_FILE=/config/joplin-sp.xml
# Leave value empty to disable session expirations, recommended when using SSO
{{ 'DELETE_EXPIRED_SESSIONS_SCHEDULE=' if joplin.saml_enabled else '' }}
LOCAL_AUTH_ENABLED={{ (not joplin.saml_enabled) | lower }}
